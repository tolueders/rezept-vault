# Supabase – Neues Projekt unter https://supabase.com/dashboard
# WICHTIG auf Vercel: NEXT_PUBLIC_* NICHT als "Sensitive" markieren (sonst fehlen sie beim Build)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini Vision API – https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# App URL (für Produktion)
NEXT_PUBLIC_APP_URL=http://localhost:3000
